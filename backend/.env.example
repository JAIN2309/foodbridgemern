# Database
MONGODB_URI=mongodb://localhost:27017/foodbridge

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Redis Configuration (for caching and performance)
REDIS_URL=redis://localhost:6379

# Twilio Configuration (for SMS support)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Performance Settings
MAX_NEARBY_DONATIONS=50
CACHE_TTL_SECONDS=120
TRUST_SCORE_UPDATE_INTERVAL=3600

# Food Safety Settings
DEFAULT_EXPIRY_BUFFER_HOURS=2
MIN_QUALITY_SCORE=3
MAX_PICKUP_ATTEMPTS=3
PICKUP_TIMEOUT_MINUTES=30

# Offline Mode Settings
OFFLINE_SYNC_ENABLED=true
SMS_NOTIFICATIONS_ENABLED=true
MAX_SMS_NOTIFICATIONS_PER_DONATION=5

# Security Settings
MIN_TRUST_SCORE_FOR_CLAIMS=30
MAX_DONATIONS_PER_DAY=10
SUSPICIOUS_ACTIVITY_THRESHOLD=10